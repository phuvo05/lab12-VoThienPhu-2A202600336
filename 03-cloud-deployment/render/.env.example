# Render Environment Variables Example
# Set these in Render Dashboard: Settings → Environment

# Optional: OpenAI API Key (if using real LLM)
# OPENAI_API_KEY=sk-your-key-here

# Environment identifier
ENVIRONMENT=production

# Python version (Render auto-detects, but can specify)
PYTHON_VERSION=3.11.0

# Note: PORT is automatically injected by Render
# Do not set PORT manually - Render uses 10000 by default
